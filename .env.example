# Supabase — values from Supabase Dashboard → Project Settings → API
# Copy this file to .env.local and fill in the real values. .env.local is gitignored.

# Project URL (e.g. https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...) — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...) — SERVER ONLY, never exposed to the browser.
# Used for privileged actions: creating users, consuming invite codes.
SUPABASE_SECRET_KEY=

# Cloudflare R2 (S3-compatible object storage). SERVER ONLY — never NEXT_PUBLIC.
# Endpoint is derived: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ngig-cloud-files
