# Supabase — values from Supabase Dashboard → Project Settings → API
# Copy this file to .env.local and fill in the real values. .env.local is gitignored.

# Project URL (e.g. https://xxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Publishable key (sb_publishable_...) — safe to expose to the browser
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Secret key (sb_secret_...) — SERVER ONLY, never exposed to the browser.
# Used for privileged actions: creating users, consuming invite codes.
SUPABASE_SECRET_KEY=

# Backblaze B2 (S3-compatible object storage). SERVER ONLY — never NEXT_PUBLIC.
# Endpoint is derived: https://s3.<B2_REGION>.backblazeb2.com
# Credentials are a B2 Application Key: keyID -> B2_KEY_ID, appKey -> B2_APP_KEY.
B2_REGION=
B2_KEY_ID=
B2_APP_KEY=
B2_BUCKET=ngig-cloud-files

# Cloudflare Turnstile (anti-bot on login/register). Free.
# Create a widget at https://dash.cloudflare.com → Turnstile.
# Site key is public (browser widget); secret key is SERVER ONLY.
# If both are empty, the captcha is skipped (handy for local dev).
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
